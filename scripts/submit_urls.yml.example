site_url: https://example.github.io
host: example.github.io
sitemap: sitemap.xml

sitemap_generate:
  static:
    - /
  globs:
    - posts/*.html

indexnow:
  enabled: true
  key: YOUR_INDEXNOW_KEY
  key_location: https://example.github.io/YOUR_INDEXNOW_KEY.txt
  endpoint: https://api.indexnow.org/indexnow
  batch_size: 10000

archive_org:
  enabled: false
  endpoint: https://web.archive.org/save
  rate_limit_seconds: 5
  wait_for_status: false
  options:
    force_get: 1
    skip_first_archive: 1
    js_behavior_timeout: 0
    if_not_archived_within: 7d

bing:
  enabled: false
  client_id:
  client_secret:
  redirect_uri: http://127.0.0.1:8765/callback
  scope: webmaster.manage
  batch_size: 500

sitemap_ping:
  enabled: true
  endpoints:
    - https://www.bing.com/ping?sitemap=
